<%- include("layout/header.ejs") %>
    <main>
      <form
        action="/"
        method="post"
      >
        <input
          type="text"
          name="pLanguage"
          placeholder="Programming Language"
        />

        <button type="submit">submit</button>
      </form>
      <ul>
      <% if(plNames.length > 0){ %>
            <% for(let i = 0; i < plNames.length; i++){ %>
                 <li><%= plNames[i] %></li>
          <% } %>
      <% } else { %>
               <p>No data found</p>
        <% } %>
      </ul>
    </main>
   <%- include("layout/footer.ejs") %>